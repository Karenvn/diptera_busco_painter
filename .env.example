# Optional shared configuration for busco_to_diptera_algs.sh

# Base directory for local data.
DATA_ROOT=/path/to/project_data

# Override individual locations if needed.
BUSCO_DIR=/path/to/project_data/busco
OUTPUT_DIR=/path/to/project_data/diptera_algs

# Input files in the working directory.
TOLID_FILE=tolids
# Optional. If unset, the wrapper searches the working directory and repo
# directory for tolid_accessions.tsv.
ACCESSION_FILE=tolid_accessions.tsv

# ALG table selection. auto uses the assembly accession to look up NCBI taxid.
LINEAGE=auto

# Optional plot label summarisation. 0 keeps chromosome-wide ALG labels.
LABEL_WINDOW_MB=20
LABEL_WINDOW_MIN_BUSCOS=5
LABEL_WINDOW_MIN_FRACTION=0.5

# Optional custom reference table path. Leave unset to use bundled tables.
# ALG_REF=/path/to/ALGs_syngraph_brachycera.tsv
